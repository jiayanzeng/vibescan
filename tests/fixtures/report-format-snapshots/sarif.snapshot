{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "invocations": [
        {
          "executionSuccessful": true,
          "properties": {
            "history": "working tree only",
            "networkActions": [
              {
                "endpoint": "https://abcdefghijklmnopqrst.supabase.co/rest/v1/",
                "intent": "get",
                "kind": "root_enumeration",
                "outcome": "root_enumerated",
                "status": 200,
                "table": null
              },
              {
                "endpoint": "https://abcdefghijklmnopqrst.supabase.co/rest/v1/private_profiles?select=*&limit=1",
                "intent": "get",
                "kind": "table_read",
                "outcome": "protected",
                "status": 403,
                "table": "private_profiles"
              },
              {
                "endpoint": "https://abcdefghijklmnopqrst.supabase.co/rest/v1/public_profiles?select=*&limit=1",
                "intent": "get",
                "kind": "table_read",
                "observed_row_count": 1,
                "outcome": "exposed",
                "status": 200,
                "table": "public_profiles"
              },
              {
                "endpoint": "db.abcdefghijklmnopqrst.supabase.co:5432",
                "intent": "select",
                "kind": "catalog_introspection",
                "outcome": "catalog_read",
                "status": null,
                "table": "profiles"
              },
              {
                "endpoint": "registry.npmjs.org",
                "intent": "get",
                "kind": "registry_existence",
                "outcome": "registry_resolved",
                "package": "left-pad@1.3.0",
                "status": 200,
                "table": null
              }
            ],
            "networkEnabled": true,
            "registryChecks": true,
            "registryNameEgress": [
              {
                "ecosystem": "npm",
                "host": "registry.npmjs.org"
              }
            ],
            "registryNewcomer": false,
            "scanStats": {
              "blobsRead": 40,
              "dedupRatioPercent": "25.00",
              "pathsWalked": 40,
              "scanBudgetHit": false,
              "truncated": false,
              "uniqueContents": 30,
              "unitsMaterialized": 30
            },
            "target": "fixtures/report-format-snapshots",
            "warnings": []
          }
        }
      ],
      "results": [
        {
          "level": "error",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/server/billing.ts"
                },
                "region": {
                  "endColumn": 57,
                  "startColumn": 17,
                  "startLine": 3
                }
              },
              "properties": {
                "locationClass": "ServerOnly",
                "provenance": "working tree"
              }
            }
          ],
          "message": {
            "text": "Secret candidate matched stripe-secret-key: secret sk_liv...1234 fingerprint snapshot-fingerprint"
          },
          "properties": {
            "category": "secret_exposure",
            "confidence": "likely",
            "related": [],
            "severity": "high"
          },
          "ruleId": "snapshot-secret"
        },
        {
          "level": "error",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "supabase/policies.sql"
                },
                "region": {}
              },
              "properties": {
                "locationClass": "ServerOnly",
                "provenance": "working tree"
              }
            }
          ],
          "message": {
            "text": "Supabase table profiles has a literal-true SELECT policy: PermissivePolicy table profiles on https://abcdefghijklmnopqrst.supabase.co; command SELECT; rowsecurity enabled; USING (true); WITH CHECK <none>"
          },
          "properties": {
            "category": "rls",
            "confidence": "confirmed",
            "related": [],
            "severity": "critical"
          },
          "ruleId": "snapshot-rls-policy"
        }
      ],
      "tool": {
        "driver": {
          "informationUri": "https://github.com/vibescan/vibescan",
          "name": "vibescan",
          "rules": [
            {
              "fullDescription": {
                "text": "The generic detector found a credential-shaped value."
              },
              "help": {
                "text": "Remove the secret from source and rotate it."
              },
              "id": "snapshot-secret",
              "name": "Secret candidate matched stripe-secret-key",
              "properties": {
                "category": "secret_exposure",
                "confidence": "likely",
                "security-severity": "8.0"
              },
              "shortDescription": {
                "text": "Secret candidate matched stripe-secret-key"
              }
            },
            {
              "fullDescription": {
                "text": "Credentialed Tier 1 catalog introspection confirmed a permissive policy whose USING predicate is the literal true."
              },
              "help": {
                "text": "Replace the literal-true predicate with a least-privilege condition."
              },
              "id": "snapshot-rls-policy",
              "name": "Supabase table profiles has a literal-true SELECT policy",
              "properties": {
                "category": "rls",
                "confidence": "confirmed",
                "security-severity": "9.5"
              },
              "shortDescription": {
                "text": "Supabase table profiles has a literal-true SELECT policy"
              }
            }
          ],
          "version": "snapshot"
        }
      }
    }
  ],
  "version": "2.1.0"
}