{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "invocations": [
        {
          "executionSuccessful": true,
          "properties": {
            "history": "working tree only",
            "networkEnabled": false,
            "target": "fixtures/report-format-snapshots",
            "warnings": []
          }
        }
      ],
      "results": [
        {
          "level": "error",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/server/billing.ts"
                },
                "region": {
                  "endColumn": 57,
                  "startColumn": 17,
                  "startLine": 3
                }
              },
              "properties": {
                "locationClass": "ServerOnly",
                "provenance": "working tree"
              }
            }
          ],
          "message": {
            "text": "Secret candidate matched stripe-secret-key: secret sk_liv...1234 fingerprint snapshot-fingerprint"
          },
          "properties": {
            "category": "secret_exposure",
            "confidence": "likely",
            "related": [],
            "severity": "high"
          },
          "ruleId": "snapshot-secret"
        }
      ],
      "tool": {
        "driver": {
          "informationUri": "https://github.com/vibescan/vibescan",
          "name": "vibescan",
          "rules": [
            {
              "fullDescription": {
                "text": "The generic detector found a credential-shaped value."
              },
              "help": {
                "text": "Remove the secret from source and rotate it."
              },
              "id": "snapshot-secret",
              "name": "Secret candidate matched stripe-secret-key",
              "properties": {
                "category": "secret_exposure",
                "confidence": "likely",
                "security-severity": "8.0"
              },
              "shortDescription": {
                "text": "Secret candidate matched stripe-secret-key"
              }
            }
          ],
          "version": "snapshot"
        }
      }
    }
  ],
  "version": "2.1.0"
}